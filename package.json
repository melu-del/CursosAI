{
  "name": "whiteboard-ai",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c green,cyan \"npm:server\" \"npm:web\"",
    "web": "vite",
    "server": "node api/server.js",
    "studio": "npx remotion studio src/video/index.jsx",
    "render": "npx remotion render src/video/index.jsx WhiteboardVideo out/video.mp4 --concurrency 2",
    "build": "tsc -b && vite build"
  },
  "dependencies": {
    "@google/genai": "^1.5.0",
    "@remotion/bundler": "4.0.290",
    "@remotion/cli": "4.0.290",
    "@remotion/player": "4.0.290",
    "@types/react-router-dom": "^5.3.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mammoth": "^1.8.0",
    "msedge-tts": "^2.0.4",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "remotion": "4.0.290"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "typescript": "~5.7.0",
    "vite": "^6.0.0"
  }
}
